{
  "compilerOptions": {
    "target": "es2021",
    "module": "node16",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["jest", "google-apps-script", "node"]
  },
  "include": ["**/*.js"],
  "exclude": ["node_modules", "dist"]
}
